/dataSources/
/dataSources.local.xml

# Environment variables
.env

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Node.js dependencies
node_modules/

# OS-specific files
.DS_Store
Thumbs.db

# IDE-specific files
.idea/
.vscode/
*.iml

# Build output
dist/
build/

# Temporary files
*.tmp
*.temp
*.swp
*.swo

# Coverage reports (tests)
coverage/

# npm lock file (optional, if you're using another package manager like Yarn)
package-lock.json

# ESLint/Prettier cache
.eslintcache
.prettiercache

# Typescript (if applicable)
*.tsbuildinfo
